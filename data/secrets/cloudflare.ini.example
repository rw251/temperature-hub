# Copy this file to /etc/letsencrypt/cloudflare.ini on the Pi and replace
# the placeholder with a restricted Cloudflare API token.
#
# Required token permission for certbot-dns-cloudflare:
# - Zone / DNS / Edit
# - Zone Resources: Include / Specific zone / rw251.com
dns_cloudflare_api_token = replace-with-cloudflare-api-token
